  "keyFeatures": [
    "Multi-role user management: administrators, students, and teachers with distinct permissions",
    "Flexible membership system with Basic, Intensive, and Premium tiers plus custom plans",
    "Class reservation lifecycle: create, assign teacher, start, finish, and rate classes",
    "Group management allowing students and teachers to be organized into learning groups",
    "Teacher contract management with salary, hours, and contract status tracking",
    "Academy capital tracking affected by memberships sold and teacher salaries",
    "File-based persistence serializing all entities to disk",
    "Java Swing desktop GUI with themed interface for all three user roles"
  ],
  "publicApiSurface": [
